# =============================================================================
# PetVerse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=PetVerse
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# ENVIRONMENT: development | testing | production
ENVIRONMENT=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-generate-a-secure-random-key-at-least-32-chars

# ─── JWT (Phase B2) ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-a-separate-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MySQL Database ────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=petverse
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# Auto-constructed from above values — you may override directly:
# DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/petverse

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIRECTORY=uploads

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:5174
# Production:  https://petverse.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── AI Services (Phase B4+) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
